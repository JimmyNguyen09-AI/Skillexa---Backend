ASPNETCORE_ENVIRONMENT=Production

ConnectionStrings__DefaultConnection=Host=your-neon-host;Port=5432;Database=neondb;Username=your-user;Password=your-password;SSL Mode=Require;Trust Server Certificate=true

Jwt__Secret=replace-with-a-random-32-byte-plus-secret
Jwt__Issuer=https://api.skillexa.com
Jwt__Audience=https://app.skillexa.com
Jwt__AccessTokenMinutes=60
Jwt__RefreshTokenDays=7

Cors__AllowedOriginsCsv=https://app.skillexa.com,https://admin.skillexa.com
AuthFrontend__CallbackUrl=https://app.skillexa.com/oauth/callback

Authentication__Google__ClientId=your-google-client-id
Authentication__Google__ClientSecret=your-google-client-secret
AiAgent__BaseUrl=https://your-zora-ai-backend
AiAgent__InternalApiKey=replace-with-shared-secret



AdminSeed__Enabled=false
AdminSeed__Name=Skillexa Admin
AdminSeed__Email=admin@your-company.com
