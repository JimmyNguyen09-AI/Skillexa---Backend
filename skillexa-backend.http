    }
  ]
}

###
# Lessons - Mark progress complete
PUT {{host}}/api/lessons/{{lessonId}}/progress
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "isCompleted": true
}

###
# Quizzes - Admin create/update quiz
PUT {{host}}/api/lessons/{{lessonId}}/quiz
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "title": "JWT Fundamentals Quiz",
  "questions": [
    {
      "orderIndex": 1,
      "prompt": "Which header usually carries a JWT?",
      "options": [
        "Authorization",
        "Cookie",
        "Origin",
        "Referer"
      ],
      "correctOptionIndex": 0,
      "explanation": "Bearer tokens are typically sent in the Authorization header."
    },
    {
      "orderIndex": 2,
      "prompt": "What should be kept secret on the server?",
      "options": [
        "Audience",
        "Issuer",
        "JWT signing secret",
        "User id"
      ],
      "correctOptionIndex": 2,
      "explanation": "The signing secret must not be exposed."
    }
  ]
}

###
# Quizzes - Get quiz
GET {{host}}/api/lessons/{{lessonId}}/quiz
Authorization: {{authorization}}
Accept: {{contentType}}

###
# Quizzes - Submit quiz
# Replace question ids after fetching the quiz.
POST {{host}}/api/lessons/{{lessonId}}/quiz/submit
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "answers": [
    {
      "questionId": "00000000-0000-0000-0000-000000000001",
      "selectedOptionIndex": 0
    },
    {
      "questionId": "00000000-0000-0000-0000-000000000002",
      "selectedOptionIndex": 2
    }
  ]
}

###
# Comments - List lesson comments
GET {{host}}/api/lessons/{{lessonId}}/comments
Accept: {{contentType}}

###
# Comments - Create root comment
# Copy comment id from response.
POST {{host}}/api/lessons/{{lessonId}}/comments
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "content": "This lesson is very clear.",
  "parentCommentId": null
}

###
# Comments - Create reply
POST {{host}}/api/lessons/{{lessonId}}/comments
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "content": "Thanks, this helped a lot.",
  "parentCommentId": "{{commentId}}"
}

###
# Comments - Update comment
PUT {{host}}/api/comments/{{commentId}}
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "content": "This lesson is very clear and practical."
}

###
# Comments - Delete comment
DELETE {{host}}/api/comments/{{commentId}}
Authorization: {{authorization}}
Accept: {{contentType}}

###
# Stats - Admin dashboard
GET {{host}}/api/stats/dashboard
Authorization: {{authorization}}
Accept: {{contentType}}
