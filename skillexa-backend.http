@host = http://localhost:5250
@contentType = application/json

# Update these after running requests below.
@accessToken = paste-access-token-here
@authorization = Bearer {{accessToken}}
@refreshToken = paste-refresh-token-here
@adminUserId = paste-admin-user-id-here
@courseId = paste-course-id-here
@courseSlug = paste-course-slug-here
@lessonId = paste-lesson-id-here
@commentId = paste-comment-id-here

###
# Root
GET {{host}}/
Accept: {{contentType}}

###
# Health
GET {{host}}/health
Accept: {{contentType}}

###
# DB Health
GET {{host}}/health/db
Accept: {{contentType}}

###
# Auth - Google OAuth login
# Open this in the browser. The Google callback must point to:
#   {{host}}/signin-google
# The frontend callback URL is controlled by AuthFrontend:CallbackUrl.
GET {{host}}/api/auth/google/login?returnUrl=http://localhost:5173/oauth/callback
Accept: {{contentType}}

###
# Auth - Refresh token
POST {{host}}/api/auth/refresh
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

###
# Auth - Revoke refresh token
POST {{host}}/api/auth/revoke
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

###
# Users - Current user
GET {{host}}/api/users/me
Authorization: {{authorization}}
Accept: {{contentType}}

###
# Users - Admin list users
# Requires an Admin token.
GET {{host}}/api/users/
Authorization: {{authorization}}
Accept: {{contentType}}

###
# Users - Admin update user role
# Replace {{adminUserId}} with a real user id.
PUT {{host}}/api/users/{{adminUserId}}/role
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "role": "Admin"
}

###
# Users - Admin update user status
PUT {{host}}/api/users/{{adminUserId}}/status
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "status": "Active"
}

###
# Courses - Public list
GET {{host}}/api/courses/
Accept: {{contentType}}

###
# Courses - Admin create course
# Requires an Admin token. Copy id and slug from response.
POST {{host}}/api/courses/
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "title": "ASP.NET Core Backend for Devs",
  "slug": "aspnet-core-backend-for-devs",
  "description": "Production-focused learning path for ASP.NET Core Minimal API.",
  "level": "Intermediate",
  "thumbnailUrl": "https://example.com/course-thumbnail.png",
  "isPublished": true
}

###
# Courses - Public detail by slug
GET {{host}}/api/courses/{{courseSlug}}
Accept: {{contentType}}

###
# Courses - Admin update course
PUT {{host}}/api/courses/{{courseId}}
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "title": "ASP.NET Core Backend for Devs - Updated",
  "slug": "aspnet-core-backend-for-devs",
  "description": "Updated course description.",
  "level": "Advanced",
  "thumbnailUrl": "https://example.com/course-thumbnail-updated.png",
  "isPublished": true
}

###
# Courses - Enroll current user
POST {{host}}/api/courses/{{courseId}}/enroll
Authorization: {{authorization}}
Accept: {{contentType}}

###
# Lessons - List by course
GET {{host}}/api/courses/{{courseId}}/lessons
Accept: {{contentType}}

###
# Lessons - Admin create lesson
# Copy lesson id from response.
POST {{host}}/api/courses/{{courseId}}/lessons
Authorization: {{authorization}}
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "title": "Authentication with JWT",
